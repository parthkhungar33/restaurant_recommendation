# Copy to .env.development and adjust if your uvicorn port is not 8000.

# Direct browser → API (CORS must allow the Vite origin). Use when proxy is wrong or you prefer explicit URL:
# VITE_API_BASE=http://127.0.0.1:8000

# Production (Vercel): set in Project Settings → Environment Variables (also as build-time for Vite):
# VITE_API_BASE=https://your-backend.example.com
# No trailing slash. Backend must allow this origin (CORS_EXTRA_ORIGINS / CORS_ORIGIN_REGEX).

# Where Vite dev server proxies /metadata, /recommendations, /health (read by vite.config.js):
# VITE_API_PROXY_TARGET=http://127.0.0.1:8010
